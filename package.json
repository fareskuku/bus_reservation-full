{
  "name": "bus-reservation-system",
  "version": "1.0.0",
  "description": "Bus Reservation System - Full Stack Application",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "npx live-server frontend --port=3000 --no-browser",
    "install:all": "cd backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "live-server": "^1.2.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
